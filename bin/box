#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

REGISTRY="ghcr.io"
OWNER="gablank"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
    cat <<EOF
${BOLD}box${RESET} - manage distrobox containers

${BOLD}USAGE${RESET}
    box <command> [arguments]

${BOLD}COMMANDS${RESET}
    list                   List all boxes with status and image tag
    enter     <box>        Enter a box
    rebuild   <box>        Pull latest image and recreate
    rebuild-all            Rebuild all boxes
    stop      <box>        Stop a box
    rm        <box>        Remove a box
    status    <box>        Show detailed box info and build metadata
    logs      <box>        Show init log
    images    <box>        List available image versions on ghcr.io
    revert    <box> <tag>  Pin box to a specific image tag and recreate

${BOLD}BOXES${RESET}
$(discover_boxes_for_help)
EOF
}

discover_boxes() {
    local dir
    for dir in "$REPO_ROOT"/*/; do
        if [[ -f "$dir/distrobox.ini" ]]; then
            basename "$dir"
        fi
    done
}

discover_boxes_for_help() {
    local b
    for b in $(discover_boxes); do
        printf "    %s\n" "$b"
    done
}

validate_box() {
    local box="$1"
    if [[ ! -f "$REPO_ROOT/$box/distrobox.ini" ]]; then
        printf "${RED}Error:${RESET} '%s' is not a valid box (no %s/distrobox.ini found)\n" "$box" "$box" >&2
        printf "Available boxes: %s\n" "$(discover_boxes | tr '\n' ' ')" >&2
        exit 1
    fi
}

get_box_name() {
    local box="$1"
    grep '^name=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2
}

get_image_line() {
    local box="$1"
    grep '^image=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2
}

get_image_tag() {
    local image
    image="$(get_image_line "$1")"
    echo "${image##*:}"
}

set_image_tag() {
    local box="$1" tag="$2"
    local ini="$REPO_ROOT/$box/distrobox.ini"
    local image_base
    image_base="$(get_image_line "$box" | sed 's|:[^:]*$||')"
    sed -i "s|^image=.*|image=${image_base}:${tag}|" "$ini"
}

container_status() {
    local name="$1"
    local line
    line="$(distrobox list 2>/dev/null | grep -w "$name" || true)"
    if [[ -z "$line" ]]; then
        echo "not created"
        return
    fi
    if echo "$line" | grep -qi "up\|running"; then
        echo "running"
    else
        echo "stopped"
    fi
}

time_ago() {
    local ts="$1"
    local then_epoch now_epoch diff
    then_epoch="$(date -d "$ts" +%s 2>/dev/null)" || { echo "$ts"; return; }
    now_epoch="$(date +%s)"
    diff=$(( now_epoch - then_epoch ))

    if (( diff < 60 )); then echo "just now"
    elif (( diff < 3600 )); then echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    else echo "$(( diff / 86400 ))d ago"
    fi
}

cmd_list() {
    printf "${BOLD}%-10s %-12s %-14s %s${RESET}\n" "BOX" "NAME" "STATUS" "IMAGE TAG"
    local box name tag status color
    for box in $(discover_boxes); do
        name="$(get_box_name "$box")"
        tag="$(get_image_tag "$box")"
        status="$(container_status "$name")"
        case "$status" in
            running)     color="$GREEN" ;;
            stopped)     color="$YELLOW" ;;
            *)           color="$RED" ;;
        esac
        printf "%-10s %-12s ${color}%-14s${RESET} %s\n" "$box" "$name" "$status" "$tag"
    done
}

cmd_enter() {
    validate_box "$1"
    local name
    name="$(get_box_name "$1")"
    exec distrobox enter "$name"
}

cmd_rebuild() {
    validate_box "$1"
    local box="$1" name
    name="$(get_box_name "$box")"
    printf "${CYAN}Rebuilding %s (%s) with latest image...${RESET}\n" "$box" "$name"
    set_image_tag "$box" "latest"
    distrobox assemble create --file "$REPO_ROOT/$box/distrobox.ini"
    printf "${GREEN}Done.${RESET}\n"
}

cmd_rebuild_all() {
    local box
    for box in $(discover_boxes); do
        cmd_rebuild "$box"
        echo ""
    done
}

cmd_stop() {
    validate_box "$1"
    local name
    name="$(get_box_name "$1")"
    distrobox stop --yes "$name"
}

cmd_rm() {
    validate_box "$1"
    local name
    name="$(get_box_name "$1")"
    distrobox rm --force "$name"
}

cmd_status() {
    validate_box "$1"
    local box="$1" name tag status image
    name="$(get_box_name "$box")"
    tag="$(get_image_tag "$box")"
    image="$(get_image_line "$box")"
    status="$(container_status "$name")"

    printf "${BOLD}Box:${RESET}     %s\n" "$box"
    printf "${BOLD}Name:${RESET}    %s\n" "$name"
    printf "${BOLD}Status:${RESET}  %s\n" "$status"
    printf "${BOLD}Image:${RESET}   %s\n" "$image"
    printf "${BOLD}Tag:${RESET}     %s\n" "$tag"
    if [[ "$tag" != "latest" ]]; then
        printf "${YELLOW}         (pinned)${RESET}\n"
    fi
    echo ""

    if [[ "$status" != "not created" ]]; then
        printf "${BOLD}Build info:${RESET}\n"
        distrobox enter "$name" -- cat /etc/box-build-info 2>/dev/null \
            | sed 's/^/  /' \
            || printf "  ${YELLOW}(not available)${RESET}\n"
    fi
}

cmd_logs() {
    validate_box "$1"
    local box="$1" home
    home="$(grep '^home=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2)"
    local logfile="$home/.box-bootstrap.log"
    if [[ -f "$logfile" ]]; then
        cat "$logfile"
    else
        printf "${YELLOW}No log file found at %s${RESET}\n" "$logfile"
    fi
}

cmd_images() {
    validate_box "$1"
    local box="$1"
    local package="box-${box}"

    printf "${BOLD}Available versions for %s:${RESET}\n\n" "$package"
    printf "${BOLD}%-16s %-28s %s${RESET}\n" "TAG" "UPDATED" "AGE"

    gh api "/users/$OWNER/packages/container/$package/versions" \
        --paginate --jq '.[]' 2>/dev/null \
    | jq -r '(.metadata.container.tags // [])[] as $tag | "\($tag)\t\(.updated_at)"' \
    | sort -t$'\t' -k1,1r \
    | while IFS=$'\t' read -r tag updated; do
        local age
        age="$(time_ago "$updated")"
        printf "%-16s %-28s %s\n" "$tag" "${updated%%T*}" "$age"
    done
}

cmd_revert() {
    validate_box "$1"
    local box="$1" tag="$2"
    printf "${CYAN}Pinning %s to tag: %s${RESET}\n" "$box" "$tag"
    set_image_tag "$box" "$tag"
    distrobox assemble create --file "$REPO_ROOT/$box/distrobox.ini"
    printf "${GREEN}Done. Use 'box rebuild %s' to return to latest.${RESET}\n" "$box"
}

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

command="$1"
shift

case "$command" in
    list)
        cmd_list
        ;;
    enter)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box enter <box>${RESET}\n" >&2; exit 1; }
        cmd_enter "$1"
        ;;
    rebuild)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box rebuild <box>${RESET}\n" >&2; exit 1; }
        cmd_rebuild "$1"
        ;;
    rebuild-all)
        cmd_rebuild_all
        ;;
    stop)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box stop <box>${RESET}\n" >&2; exit 1; }
        cmd_stop "$1"
        ;;
    rm)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box rm <box>${RESET}\n" >&2; exit 1; }
        cmd_rm "$1"
        ;;
    status)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box status <box>${RESET}\n" >&2; exit 1; }
        cmd_status "$1"
        ;;
    logs)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box logs <box>${RESET}\n" >&2; exit 1; }
        cmd_logs "$1"
        ;;
    images)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box images <box>${RESET}\n" >&2; exit 1; }
        cmd_images "$1"
        ;;
    revert)
        [[ $# -ge 2 ]] || { printf "${RED}Usage: box revert <box> <tag>${RESET}\n" >&2; exit 1; }
        cmd_revert "$1" "$2"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        printf "${RED}Unknown command: %s${RESET}\n\n" "$command" >&2
        usage >&2
        exit 1
        ;;
esac
