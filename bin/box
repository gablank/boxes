#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

REGISTRY="ghcr.io"

_BOX_COMMANDS=(init list enter set-image build assemble assemble-all pull stop status logs images completions help)
_BOX_COMMANDS_WITH_BOX=(enter set-image build assemble pull stop status logs images)

_detect_owner() {
    local remote
    remote="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)"
    [[ -z "$remote" ]] && return
    remote="${remote#*github.com:}"
    remote="${remote#*github.com/}"
    echo "${remote%%/*}"
}

compile_toml() {
    local box="$1"
    python3 "$REPO_ROOT/scripts/compile-box-toml.py" "$REPO_ROOT/$box"
}

ensure_compiled() {
    local box="$1"
    local toml="$REPO_ROOT/$box/box.toml"
    local ini="$REPO_ROOT/$box/distrobox.ini"
    if [[ ! -f "$ini" || "$toml" -nt "$ini" ]]; then
        compile_toml "$box"
    fi
}

OWNER="${BOX_OWNER:-$(_detect_owner)}"
: "${OWNER:=gablank}"


RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
    cat <<EOF
${BOLD}box${RESET} - manage distrobox containers

${BOLD}USAGE${RESET}
    box <command> [arguments]

${BOLD}COMMANDS${RESET}
    init        [owner]      Set image registry owner in all box.toml files (default: git remote)
    list                     List all boxes with status and image tag
    enter       <box>        Enter a box
    set-image   <box> [tag]  Set the image tag in box.toml (default: latest)
    build       <box>        Build container image locally (base + box). Does not restart.
    assemble    <box>        Recreate box from box.toml. ${RED}Stops the box.${RESET}
    assemble-all             Recreate all boxes. ${RED}Stops all boxes.${RESET}
    pull        <box> [tag]  Pull image from registry (default: current tag). Does not restart.
    stop        <box>        Stop a box
    status      <box>        Show detailed box info and build metadata
    logs        <box>        Show init log
    images      <box>        List available image versions on ghcr.io
    completions <shell>      Print or install shell completions (bash|zsh|install)

${BOLD}BOXES${RESET}
$(discover_boxes_for_help)
EOF
}

discover_boxes() {
    local dir
    for dir in "$REPO_ROOT"/*/; do
        if [[ -f "$dir/box.toml" ]]; then
            basename "$dir"
        fi
    done
}

discover_boxes_for_help() {
    local b
    for b in $(discover_boxes); do
        printf "    %s\n" "$b"
    done
}

validate_box() {
    local box="$1"
    if [[ ! -f "$REPO_ROOT/$box/box.toml" ]]; then
        printf "${RED}Error:${RESET} '%s' is not a valid box (no %s/box.toml found)\n" "$box" "$box" >&2
        printf "Available boxes: %s\n" "$(discover_boxes | tr '\n' ' ')" >&2
        exit 1
    fi
}

get_box_name() {
    local box="$1"
    ensure_compiled "$box"
    grep '^name=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2
}

is_rootful() {
    local box="$1"
    ensure_compiled "$box"
    grep -q '^root=true' "$REPO_ROOT/$box/distrobox.ini"
}

root_flag() {
    local box="$1"
    is_rootful "$box" && printf '%s' "--root" || true
}

get_image_line() {
    local box="$1"
    ensure_compiled "$box"
    grep '^image=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2
}

get_image_tag() {
    local image
    image="$(get_image_line "$1")"
    echo "${image##*:}"
}

set_image_tag() {
    local box="$1" tag="$2"
    local toml="$REPO_ROOT/$box/box.toml"
    local image_base
    image_base="$(get_image_line "$box" | sed 's|:[^:]*$||')"
    sed -i "s|^image = .*|image = \"${image_base}:${tag}\"|" "$toml"
    compile_toml "$box"
}

container_status() {
    local name="$1" rflag="${2:-}"
    local line
    line="$(distrobox list $rflag 2>/dev/null | grep -w "$name" || true)"
    if [[ -z "$line" ]]; then
        echo "not created"
        return
    fi
    if echo "$line" | grep -qi "up\|running"; then
        echo "running"
    else
        echo "stopped"
    fi
}

time_ago() {
    local ts="$1"
    # Normalize YYYY-MM-DDTHHMM → "YYYY-MM-DD HH:MM UTC" for date -d
    if [[ "$ts" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{4}$ ]]; then
        ts="${ts:0:10} ${ts:11:2}:${ts:13:2} UTC"
    fi
    local then_epoch now_epoch diff
    then_epoch="$(date -d "$ts" +%s 2>/dev/null)" || { echo "$1"; return; }
    now_epoch="$(date +%s)"
    diff=$(( now_epoch - then_epoch ))

    if (( diff < 60 )); then echo "just now"
    elif (( diff < 3600 )); then echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    else echo "$(( diff / 86400 ))d ago"
    fi
}

cmd_init() {
    local owner="${1:-$OWNER}"
    if [[ -z "$owner" ]]; then
        printf "${RED}Error: could not detect GitHub owner from git remote.${RESET}\n" >&2
        printf "Run: box init <github-username>\n" >&2
        exit 1
    fi
    printf "${CYAN}Configuring boxes for GitHub owner: %s${RESET}\n\n" "$owner"
    local box toml tag new_image
    for box in $(discover_boxes); do
        toml="$REPO_ROOT/$box/box.toml"
        tag="$(get_image_tag "$box")"
        new_image="$REGISTRY/$owner/box-$box:$tag"
        sed -i "s|^image = .*|image = \"$new_image\"|" "$toml"
        compile_toml "$box"
        printf "  %-10s %s\n" "$box" "$new_image"
    done
    printf "\n${GREEN}Done. Run 'box assemble <box>' to apply the new image.${RESET}\n"
}

cmd_list() {
    printf "${BOLD}%-10s %-12s %-14s %s${RESET}\n" "BOX" "NAME" "STATUS" "IMAGE TAG"
    local box name tag status color
    for box in $(discover_boxes); do
        name="$(get_box_name "$box")"
        tag="$(get_image_tag "$box")"
        status="$(container_status "$name" "$(root_flag "$box")")"
        case "$status" in
            running)     color="$GREEN" ;;
            stopped)     color="$YELLOW" ;;
            *)           color="$RED" ;;
        esac
        printf "%-10s %-12s ${color}%-14s${RESET} %s\n" "$box" "$name" "$status" "$tag"
    done
}

cmd_enter() {
    validate_box "$1"
    local name rflag
    name="$(get_box_name "$1")"
    rflag="$(root_flag "$1")"
    exec distrobox enter $rflag "$name"
}

cmd_set_image() {
    validate_box "$1"
    local box="$1" tag="${2:-latest}"
    set_image_tag "$box" "$tag"
    printf "${GREEN}Image for %s set to: %s${RESET}\n" "$box" "$(get_image_line "$box")"
}

# Auto-create host directories for volume= mounts before assembling.
# Only volume= lines are processed — these must be directories.
# Non-directory mounts (sockets, files) belong in additional_flags --volume.
ensure_host_dirs() {
    local ini="$1" line host_path
    while IFS= read -r line; do
        # Expand ~ and env vars in the host path
        host_path="$(eval printf '%s' "${line%%:*}")"
        if [[ -n "$host_path" && ! -d "$host_path" ]]; then
            printf "${CYAN}Creating host directory: %s${RESET}\n" "$host_path"
            mkdir -p "$host_path"
        fi
    done < <(grep -oP '^volume=\K.+' "$ini")
    # Also ensure home= directory exists
    local home_val
    home_val="$(grep -oP '^home=\K.+' "$ini" || true)"
    if [[ -n "$home_val" ]]; then
        home_val="$(eval printf '%s' "$home_val")"
        if [[ ! -d "$home_val" ]]; then
            printf "${CYAN}Creating home directory: %s${RESET}\n" "$home_val"
            mkdir -p "$home_val"
        fi
    fi
}

cmd_build() {
    validate_box "$1"
    local box="$1"
    local base_image="$REGISTRY/$OWNER/box-base:latest"
    local box_image="$REGISTRY/$OWNER/box-$box:latest"
    local date_tag
    date_tag="$(date -u '+%Y-%m-%dT%H%M')"

    local build_sha local_tag
    build_sha="$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || printf 'local')"
    local_tag="local-${date_tag}"

    printf "${CYAN}Building base image...${RESET}\n"
    podman build --no-cache \
        -f "$REPO_ROOT/Containerfile.base" \
        --build-arg "BUILD_DATE=$date_tag" \
        --build-arg "BUILD_SHA=$build_sha" \
        -t "$base_image" \
        "$REPO_ROOT"

    printf "\n${CYAN}Building box-%s image...${RESET}\n" "$box"
    podman build --no-cache \
        -f "$REPO_ROOT/$box/Containerfile" \
        --build-arg "BASE_IMAGE=$base_image" \
        --build-arg "BUILD_DATE=$date_tag" \
        --build-arg "BUILD_SHA=$build_sha" \
        -t "$box_image" \
        -t "$REGISTRY/$OWNER/box-$box:$local_tag" \
        "$REPO_ROOT"

    printf "\n${GREEN}Built %s (%s)${RESET}\n" "$box_image" "$local_tag"
    printf "Image built. The running box is ${BOLD}not affected${RESET}.\n"
    printf "Run ${BOLD}box assemble %s${RESET} to recreate the container from this image (${RED}stops the box${RESET}).\n" "$box"
}

cmd_assemble() {
    validate_box "$1"
    local box="$1"
    compile_toml "$box"
    local name
    name="$(get_box_name "$box")"
    printf "${CYAN}Assembling %s (%s) from %s...${RESET}\n" "$box" "$name" "$(get_image_line "$box")"
    ensure_host_dirs "$REPO_ROOT/$box/distrobox.ini"
    distrobox assemble create --file "$REPO_ROOT/$box/distrobox.ini"
    printf "${GREEN}Done.${RESET}\n"
}

cmd_assemble_all() {
    local box
    for box in $(discover_boxes); do
        cmd_assemble "$box"
        echo ""
    done
}

cmd_pull() {
    validate_box "$1"
    local box="$1" tag="${2:-}"
    local image
    image="$(get_image_line "$box")"
    if [[ -n "$tag" ]]; then
        image="${image%:*}:${tag}"
    fi
    printf "${CYAN}Pulling %s...${RESET}\n" "$image"
    podman pull "$image"
    printf "${GREEN}Done.${RESET}\n"
}

cmd_stop() {
    validate_box "$1"
    local name rflag
    name="$(get_box_name "$1")"
    rflag="$(root_flag "$1")"
    distrobox stop $rflag --yes "$name"
}

cmd_status() {
    validate_box "$1"
    local box="$1" name tag status image rflag
    name="$(get_box_name "$box")"
    tag="$(get_image_tag "$box")"
    image="$(get_image_line "$box")"
    rflag="$(root_flag "$box")"
    status="$(container_status "$name" "$rflag")"

    printf "${BOLD}Box:${RESET}     %s\n" "$box"
    printf "${BOLD}Name:${RESET}    %s\n" "$name"
    printf "${BOLD}Status:${RESET}  %s\n" "$status"
    printf "${BOLD}Image:${RESET}   %s\n" "$image"
    printf "${BOLD}Tag:${RESET}     %s\n" "$tag"
    if [[ "$tag" != "latest" ]]; then
        printf "${YELLOW}         (pinned)${RESET}\n"
    fi
    echo ""

    if [[ "$status" != "not created" ]]; then
        printf "${BOLD}Build info:${RESET}\n"
        distrobox enter $rflag "$name" -- cat /etc/box-build-info 2>/dev/null \
            | sed 's/^/  /' \
            || printf "  ${YELLOW}(not available)${RESET}\n"
    fi
}

cmd_logs() {
    validate_box "$1"
    local box="$1" home
    ensure_compiled "$box"
    home="$(grep '^home=' "$REPO_ROOT/$box/distrobox.ini" | head -1 | cut -d= -f2)"
    home="$(eval echo "$home")"
    local logfile="$home/.box-bootstrap.log"
    if [[ -f "$logfile" ]]; then
        cat "$logfile"
    else
        printf "${YELLOW}No log file found at %s${RESET}\n" "$logfile"
    fi
}

get_running_build_date() {
    local name="$1"
    podman exec "$name" cat /etc/box-build-info 2>/dev/null \
        | grep '^build_date=' | cut -d= -f2 || true
}

_image_markers() {
    local tag="$1" current_build_date="$2" next_tag="$3"
    local marks=""
    [[ -n "$current_build_date" && "$tag" == "$current_build_date" ]] && marks+="${GREEN}← current${RESET}  "
    [[ "$tag" == "$next_tag" ]] && marks+="${YELLOW}← next${RESET}"
    printf '%s' "$marks"
}

cmd_images() {
    validate_box "$1"
    local box="$1"
    local repo="$OWNER/box-$box"
    local ini_tag current_build_date
    ini_tag="$(get_image_tag "$box")"
    current_build_date="$(get_running_build_date "$(get_box_name "$box")")"

    local token
    token="$(curl -sf \
        "https://$REGISTRY/token?scope=repository:${repo}:pull&service=ghcr.io" \
        | grep -o '"token":"[^"]*"' | cut -d'"' -f4)"
    if [[ -z "$token" ]]; then
        printf "${RED}Error: could not get registry token for %s${RESET}\n" "$repo" >&2
        exit 1
    fi

    local tags_json
    tags_json="$(curl -sf \
        -H "Authorization: Bearer $token" \
        "https://$REGISTRY/v2/${repo}/tags/list")"

    local date_tags latest_date has_latest next_tag
    date_tags="$(printf '%s' "$tags_json" \
        | grep -o '"[0-9][^"]*"' | tr -d '"' | sort -r)"
    latest_date="$(printf '%s' "$date_tags" | head -1)"
    has_latest=""
    printf '%s' "$tags_json" | grep -q '"latest"' && has_latest=1

    # Resolve "latest" ini tag to the concrete date tag it points to
    next_tag="$ini_tag"
    [[ "$ini_tag" == "latest" && -n "$has_latest" && -n "$latest_date" ]] && next_tag="$latest_date"

    # Collect local-only tags from podman images
    local local_tags
    local_tags="$(podman images --format '{{.Tag}}' "$REGISTRY/$repo" 2>/dev/null \
        | grep '^local-' | sort -r || true)"

    printf "${BOLD}Available versions for box-%s:${RESET}\n\n" "$box"
    printf "${BOLD}%-24s %-12s %s${RESET}\n" "TAG" "AGE" "NOTES"

    # Show local builds first
    while IFS= read -r tag; do
        [[ -z "$tag" ]] && continue
        local local_date="${tag#local-}"
        printf "%-24s %-12s %b\n" "$tag" "$(time_ago "$local_date")" "${CYAN}local${RESET}"
    done <<< "$local_tags"

    # Show registry tags
    while IFS= read -r tag; do
        [[ -z "$tag" ]] && continue
        local display_tag="$tag"
        [[ -n "$has_latest" && "$tag" == "$latest_date" ]] && display_tag="$tag (latest)"
        printf "%-24s %-12s %b\n" "$display_tag" "$(time_ago "$tag")" "$(_image_markers "$tag" "$current_build_date" "$next_tag")"
    done <<< "$date_tags"
}

_completions_bash() {
    cat <<'BASH'
_box_completion() {
    local cur prev words cword
    _init_completion 2>/dev/null || {
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        cword=$COMP_CWORD
        words=("${COMP_WORDS[@]}")
    }

    local commands
    commands="$(box --list-boxes 2>/dev/null | tr '\n' ' ')"

    if [[ $cword -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "init list enter set-image build assemble assemble-all pull stop status logs images completions help" -- "$cur") )
        return 0
    fi

    case "${words[1]}" in
        enter|set-image|build|assemble|pull|stop|status|logs|images)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
            fi
            ;;
        completions)
            if [[ $cword -eq 2 ]]; then
                COMPREPLY=( $(compgen -W "bash zsh install" -- "$cur") )
            fi
            ;;
    esac
    return 0
}
complete -F _box_completion box
BASH
}

_completions_zsh() {
    cat <<'ZSH'
#compdef box

_box() {
    local state line
    typeset -A opt_args

    _arguments \
        '1: :_box_commands' \
        '*:: :->args'

    case $state in
        args)
            case $words[1] in
                enter|set-image|build|assemble|pull|stop|status|logs|images)
                    _arguments '1: :_box_boxes'
                    ;;
                completions)
                    _arguments '1: :(bash zsh install)'
                    ;;
            esac
            ;;
    esac
}

_box_commands() {
    local -a cmds
    cmds=(
        'init:set image registry owner in all box.toml files'
        'list:list all boxes with status and image tag'
        'enter:enter a box'
        'set-image:set the image tag in box.toml'
        'build:build container image locally, does not restart'
        'assemble:recreate box from box.toml (stops the box)'
        'assemble-all:recreate all boxes (stops all boxes)'
        'pull:pull image from registry, does not restart'
        'stop:stop a box'
        'status:show detailed box info and build metadata'
        'logs:show init log'
        'images:list available image versions on ghcr.io'
        'completions:print or install shell completions'
        'help:show help'
    )
    _describe 'command' cmds
}

_box_boxes() {
    local -a boxes
    boxes=( ${(f)"$(box --list-boxes 2>/dev/null)"} )
    _describe 'box' boxes
}

_box "$@"
ZSH
}

_completions_install() {
    local shell_name
    shell_name="$(basename "${SHELL:-}")"
    local installed=false

    if [[ "$shell_name" == "zsh" || -f "$HOME/.zshrc" ]]; then
        local marker='# Added by boxes completions'
        local eval_line='eval "$(box completions zsh)"'
        if ! grep -qF "$eval_line" "$HOME/.zshrc" 2>/dev/null; then
            printf '\n%s\n%s\n' "$marker" "$eval_line" >> "$HOME/.zshrc"
            printf "${GREEN}Installed zsh completions in ~/.zshrc${RESET}\n"
        else
            printf "${CYAN}zsh completions already installed in ~/.zshrc${RESET}\n"
        fi
        installed=true
    fi

    if [[ "$shell_name" == "bash" || -f "$HOME/.bashrc" ]]; then
        local eval_line='eval "$(box completions bash)"'
        if ! grep -qF "$eval_line" "$HOME/.bashrc" 2>/dev/null; then
            printf '\n# Added by boxes completions\n%s\n' "$eval_line" >> "$HOME/.bashrc"
            printf "${GREEN}Installed bash completions in ~/.bashrc${RESET}\n"
        else
            printf "${CYAN}bash completions already installed in ~/.bashrc${RESET}\n"
        fi
        installed=true
    fi

    if [[ "$installed" == false ]]; then
        printf "${YELLOW}Could not find ~/.zshrc or ~/.bashrc to install completions.${RESET}\n"
        printf "Run one of these manually:\n"
        printf "  echo 'eval \"\$(box completions bash)\"' >> ~/.bashrc\n"
        printf "  echo 'eval \"\$(box completions zsh)\"'  >> ~/.zshrc\n"
        exit 1
    fi
    printf "${YELLOW}Restart your shell (or source the rc file) to activate completions.${RESET}\n"
}

cmd_completions() {
    local subcmd="${1:-}"
    case "$subcmd" in
        bash)    _completions_bash ;;
        zsh)     _completions_zsh ;;
        install) _completions_install ;;
        *)
            printf "${RED}Usage: box completions <bash|zsh|install>${RESET}\n" >&2
            exit 1
            ;;
    esac
}

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

command="$1"
shift

case "$command" in
    --list-boxes)
        discover_boxes
        ;;
    completions)
        cmd_completions "${1:-}"
        ;;
    init)
        cmd_init "${1:-}"
        ;;
    list)
        cmd_list
        ;;
    enter)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box enter <box>${RESET}\n" >&2; exit 1; }
        cmd_enter "$1"
        ;;
    set-image)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box set-image <box> [tag]${RESET}\n" >&2; exit 1; }
        cmd_set_image "$1" "${2:-}"
        ;;
    build)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box build <box>${RESET}\n" >&2; exit 1; }
        cmd_build "$1"
        ;;
    assemble)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box assemble <box>${RESET}\n" >&2; exit 1; }
        cmd_assemble "$1"
        ;;
    assemble-all)
        cmd_assemble_all
        ;;
    pull)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box pull <box> [tag]${RESET}\n" >&2; exit 1; }
        cmd_pull "$1" "${2:-}"
        ;;
    stop)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box stop <box>${RESET}\n" >&2; exit 1; }
        cmd_stop "$1"
        ;;
    status)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box status <box>${RESET}\n" >&2; exit 1; }
        cmd_status "$1"
        ;;
    logs)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box logs <box>${RESET}\n" >&2; exit 1; }
        cmd_logs "$1"
        ;;
    images)
        [[ $# -ge 1 ]] || { printf "${RED}Usage: box images <box>${RESET}\n" >&2; exit 1; }
        cmd_images "$1"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        printf "${RED}Unknown command: %s${RESET}\n\n" "$command" >&2
        usage >&2
        exit 1
        ;;
esac
