ARG BASE_IMAGE=ghcr.io/gablank/box-base:latest
FROM ${BASE_IMAGE}

ARG BUILD_DATE=unknown
ARG BUILD_SHA=unknown

# Work-specific packages:
#   kubectl, k9s: Kubernetes CLI + TUI dashboard
#   qemu-base, qemu-img: VM emulation and disk image tools
#   glab: GitLab CLI
#   podman + netavark + aardvark-dns + fuse-overlayfs + slirp4netns:
#     local rootless container runtime so docker/compose-spawned containers
#     live in workbox's netns (not the host's). Replaces the host podman.sock
#     bind that priv still uses.
RUN pacman -Syu --noconfirm --needed kubectl k9s qemu-base qemu-img glab \
    podman netavark aardvark-dns fuse-overlayfs slirp4netns && \
    pacman -Scc --noconfirm && \
    rm -rf /var/cache/pacman/pkg/*

COPY work/local-bin/ /usr/local/bin/
RUN chmod +x /usr/local/bin/* 2>/dev/null || true

RUN printf 'build_date=%s\nbuild_sha=%s\nimage=box-work\n' \
        "$BUILD_DATE" "$BUILD_SHA" > /etc/box-build-info
